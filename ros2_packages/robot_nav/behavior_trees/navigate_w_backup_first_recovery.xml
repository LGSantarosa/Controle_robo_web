<!--
  CÓPIA do BT default do Nav2 jazzy
  (navigate_to_pose_w_replanning_and_recovery.xml), com UMA mudança: a ordem do
  RoundRobin de recovery. Replan a 1 Hz + recoveries idênticos; só reordenados.

  POR QUÊ (2026-06-10, pedido do usuário): este robô (skid-steer 4 rodas) costuma
  travar ENCURRALADO perto das paredes. Girar (Spin) no lugar quando está
  espremido NÃO resolve — não há pra onde virar. Dar RÉ "volta de onde veio", que
  era espaço livre. Então invertemos a prioridade:

    default:  Clear -> Spin -> Wait -> BackUp   (ré é a ÚLTIMA tentativa)
    aqui:     Clear -> BackUp -> Wait -> Spin   (ré logo após limpar o costmap)

  - ClearingActions continua 1º: é barato e sem movimento; muitas vezes o
    obstáculo era stale no costmap e o FollowPath já volta a funcionar.
  - BackUp 0.30 m / 0.15 m/s (= default): retrai pra trás (checa colisão atrás via
    simulate_ahead_time do behavior_server, não dá ré em cima de obstáculo).
  - Spin vira ÚLTIMO recurso (só se clear+ré+wait não destravaram).

  O contorno SUAVE (sem nem chegar aqui) vem do replan@1Hz + obstacle_layer
  marcando o /scan: na maioria das vezes o planner re-rota pelo lado livre ANTES
  de o robô travar. Este BT é a rede de segurança do caso "encurralado".

  Apontado por nav2.launch.py via default_nav_to_pose_bt_xml (não-hardcoded:
  get_package_share_directory). NÃO mexe no navigate_through_poses (usa o default).
-->
<root BTCPP_format="4" main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">
      <PipelineSequence name="NavigateWithReplanning">
        <ControllerSelector selected_controller="{selected_controller}" default_controller="FollowPath" topic_name="controller_selector"/>
        <PlannerSelector selected_planner="{selected_planner}" default_planner="GridBased" topic_name="planner_selector"/>
        <RateController hz="1.0">
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">
            <ComputePathToPose goal="{goal}" path="{path}" planner_id="{selected_planner}" error_code_id="{compute_path_error_code}"/>
            <Sequence>
              <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
          </RecoveryNode>
        </RateController>
        <RecoveryNode number_of_retries="1" name="FollowPath">
          <FollowPath path="{path}" controller_id="{selected_controller}" error_code_id="{follow_path_error_code}"/>
          <Sequence>
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
            <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>
        </RecoveryNode>
      </PipelineSequence>
      <Sequence>
        <Fallback>
          <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
          <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
        </Fallback>
        <ReactiveFallback name="RecoveryFallback">
          <GoalUpdated/>
          <RoundRobin name="RecoveryActions">
            <Sequence name="ClearingActions">
              <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Subtree" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
            <BackUp backup_dist="0.30" backup_speed="0.15" error_code_id="{backup_code_id}"/>
            <Wait wait_duration="5.0"/>
            <Spin spin_dist="1.57" error_code_id="{spin_error_code}"/>
          </RoundRobin>
        </ReactiveFallback>
      </Sequence>
    </RecoveryNode>
  </BehaviorTree>
</root>

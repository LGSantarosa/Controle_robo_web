<?xml version="1.0"?>
<!--
  Husky customizado (dimensões reduzidas):
    Corpo 0.31 x 0.24 x 0.14 m | Altura total 0.20 m (do chão ao topo)
    Rodas raio 0.06 m, largura 0.03 m
    Track 0.24 m (rodas flush com o corpo)
    LiDAR centralizado em cima do corpo
    Cor: amarelo Husky

  Tópicos ROS: /cmd_vel, /odom, /scan, /tf, /joint_states
  Diff-drive com 2 rodas traseiras + roda boba (sphere) na frente.
-->
<sdf version="1.9">
  <model name="husky">
    <!-- base_link center = wheel_radius + body_height/2 = 0.06 + 0.07 = 0.13 -->
    <pose>0 0 0.13 0 0 0</pose>

    <!-- ====== base_link (chassi) ====== -->
    <link name="base_link">
      <inertial>
        <mass>3.0</mass>
        <inertia>
          <ixx>0.025</ixx><iyy>0.035</iyy><izz>0.05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="body_visual">
        <geometry><box><size>0.31 0.24 0.14</size></box></geometry>
        <material>
          <ambient>0.95 0.75 0.05 1</ambient>
          <diffuse>1.0 0.82 0.0 1</diffuse>
          <specular>0.3 0.3 0.3 1</specular>
        </material>
      </visual>
      <collision name="body_collision">
        <geometry><box><size>0.31 0.24 0.14</size></box></geometry>
      </collision>
      <!-- Topo preto (painel decorativo) -->
      <visual name="top_visual">
        <pose>0 0 0.075 0 0 0</pose>
        <geometry><box><size>0.26 0.20 0.01</size></box></geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.15 0.15 0.15 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- ====== Rodas traseiras (2, tração) ======
         x: -0.09
         y: ±0.12 (track 0.24, flush com o corpo)
         z: -0.07 (centro da roda em z=0.06 no mundo)
    -->
    <link name="rear_left_wheel">
      <pose>-0.09 0.12 -0.07 -1.5707 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="v"><geometry><cylinder><radius>0.06</radius><length>0.03</length></cylinder></geometry>
        <material><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      <collision name="c"><geometry><cylinder><radius>0.06</radius><length>0.03</length></cylinder></geometry>
        <surface><friction><ode><mu>1.2</mu><mu2>0.8</mu2></ode></friction></surface></collision>
    </link>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>base_link</parent><child>rear_left_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="rear_right_wheel">
      <pose>-0.09 -0.12 -0.07 -1.5707 0 0</pose>
      <inertial>
        <mass>0.2</mass>
        <inertia>
          <ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="v"><geometry><cylinder><radius>0.06</radius><length>0.03</length></cylinder></geometry>
        <material><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      <collision name="c"><geometry><cylinder><radius>0.06</radius><length>0.03</length></cylinder></geometry>
        <surface><friction><ode><mu>1.2</mu><mu2>0.8</mu2></ode></friction></surface></collision>
    </link>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>base_link</parent><child>rear_right_wheel</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <!-- ====== Roda boba (caster) na frente ======
         Sphere fixa ao corpo com atrito baixo — desliza livremente
         em qualquer direção. Raio 0.03, centro em z=-0.10 rel a base_link
         (z=0.03 no mundo), então o fundo toca o chão.
    -->
    <link name="caster_wheel">
      <pose>0.12 0 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>1e-5</ixx><iyy>1e-5</iyy><izz>1e-5</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="v"><geometry><sphere><radius>0.03</radius></sphere></geometry>
        <material><diffuse>0.1 0.1 0.1 1</diffuse></material></visual>
      <collision name="c"><geometry><sphere><radius>0.03</radius></sphere></geometry>
        <surface><friction><ode><mu>0.01</mu><mu2>0.01</mu2></ode></friction></surface></collision>
    </link>
    <joint name="caster_joint" type="fixed">
      <parent>base_link</parent><child>caster_wheel</child>
    </joint>

    <!-- ====== LiDAR 2D centralizado em cima ======
         x=0, y=0, z = body_height/2 + lidar_half = 0.07 + 0.02 = 0.09
    -->
    <link name="base_laser">
      <pose>0 0 0.09 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0001</ixx><iyy>0.0001</iyy><izz>0.0001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="lidar_visual">
        <geometry><cylinder><radius>0.038</radius><length>0.04</length></cylinder></geometry>
        <material><diffuse>0.0 0.3 0.8 1</diffuse></material>
      </visual>
      <sensor name="lidar" type="gpu_lidar">
        <update_rate>10</update_rate>
        <topic>scan</topic>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <gz_frame_id>base_laser</gz_frame_id>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.10</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
        </lidar>
      </sensor>
    </link>
    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>base_laser</child>
    </joint>

    <!-- ====== Mock visual da câmera frontal ======
         O sensor RGB-D foi removido (sim.launch.py não faz bridge das
         /camera/* — o sensor consumia CPU/GPU sem dados chegando ao ROS).
         O link visual + joint ficam para reservar a posição/TF caso volte
         no futuro; remova de vez se decidir que não.
    -->
    <link name="camera_link">
      <pose>0.16 0 0.02 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.00001</ixx><iyy>0.00001</iyy><izz>0.00001</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="camera_visual">
        <geometry><box><size>0.025 0.080 0.025</size></box></geometry>
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
    </joint>

    <!-- ====== Plugins ====== -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_radius>0.06</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <tf_topic>/tf</tf_topic>
      <max_linear_acceleration>1.5</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>

    <plugin filename="gz-sim-pose-publisher-system"
            name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <publish_sensor_pose>true</publish_sensor_pose>
      <publish_collision_pose>false</publish_collision_pose>
      <publish_visual_pose>false</publish_visual_pose>
      <publish_nested_model_pose>false</publish_nested_model_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <!-- static_publisher=false: o robot_state_publisher do sim.launch.py
           já cobre os TFs estáticos via URDF (base_link → base_laser, rodas).
           Com true, o PosePublisher do GZ duplicava esses TFs no /tf e o
           tf_buffer alternava entre as duas fontes a cada lookup. -->
      <static_publisher>false</static_publisher>
      <static_update_frequency>1</static_update_frequency>
    </plugin>
  </model>
</sdf>

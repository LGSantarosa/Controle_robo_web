<?xml version="1.0"?>
<!--
  Husky miniatura (URDF de apoio) — dimensões batem 1:1 com o husky.sdf
  simulado no Gazebo. O robot_state_publisher usa esta árvore pra fornecer
  os TFs estáticos que o slam_toolbox e o Nav2 consomem (principalmente
  base_link → base_laser). O odom → base_link vem do plugin DiffDrive,
  então base_link NÃO pode ter um outro pai aqui (sem base_footprint).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="husky">

  <xacro:property name="wheel_radius"  value="0.06"/>
  <xacro:property name="wheel_width"   value="0.03"/>
  <xacro:property name="track"         value="0.24"/>   <!-- separação esq-dir -->
  <xacro:property name="rear_wheel_x"  value="-0.09"/>  <!-- eixo traseiro -->
  <xacro:property name="caster_x"      value="0.12"/>
  <xacro:property name="caster_radius" value="0.03"/>

  <xacro:property name="body_length"   value="0.31"/>
  <xacro:property name="body_width"    value="0.24"/>
  <xacro:property name="body_height"   value="0.14"/>

  <!-- LiDAR centralizado em cima do corpo, coerente com husky.sdf -->
  <xacro:property name="lidar_x"       value="0.0"/>
  <xacro:property name="lidar_z"       value="0.09"/>

  <link name="base_link">
    <visual>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
      <material name="husky_yellow"><color rgba="1.0 0.82 0.0 1.0"/></material>
    </visual>
    <collision>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.035" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <xacro:macro name="wheel" params="name x y">
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${-body_height/2 + wheel_radius - wheel_radius}" rpy="${-pi/2} 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
    <link name="${name}">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0005"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:wheel name="rear_left_wheel"   x="${rear_wheel_x}" y="${ track/2}"/>
  <xacro:wheel name="rear_right_wheel"  x="${rear_wheel_x}" y="${-track/2}"/>

  <!-- Roda boba (caster) — sphere fixa na frente, bate com o husky.sdf -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <!-- z = -(wheel_radius + body_height/2 - caster_radius) p/ alinhar
         com o chão quando base_link está em z=wheel_radius+body_height/2 -->
    <origin xyz="${caster_x} 0 -0.10" rpy="0 0 0"/>
  </joint>
  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="${caster_radius}"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><sphere radius="${caster_radius}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/>
    </inertial>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_laser"/>
    <origin xyz="${lidar_x} 0 ${lidar_z}" rpy="0 0 0"/>
  </joint>

  <link name="base_laser">
    <visual>
      <geometry><cylinder radius="0.038" length="0.04"/></geometry>
      <material name="blue"><color rgba="0.0 0.3 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.038" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- Câmera RGB-D frontal — bate com a posição do <link name="camera_link">
       no husky.sdf. URDF aqui só pra robot_state_publisher publicar o TF
       estático base_link → camera_link, que o Nav2 e o map_service usam
       pra transformar o point cloud e a imagem. -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.16 0 0.02" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.025 0.080 0.025"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

</robot>

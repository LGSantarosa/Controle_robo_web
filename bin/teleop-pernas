#!/usr/bin/env bash
# teleop-pernas — dirige a "pessoa" (2 pernas do sala_grande.sdf) pelo TECLADO
# NUMERICO, pra estressar o motion_guard no sim.
#
# Uso: com o sim de pe, rodar `bin/teleop-pernas` num terminal e dirigir com o
# foco NELE (a tecla fica valendo ate a proxima; 5 para):
#
#        7  8  9        8 = frente (+x do mapa)   2 = re
#        4  5  6        4 = esquerda (+y)         6 = direita
#        1  2  3        diagonais nos cantos      5 = PARA
#
#        + / -  = mais/menos velocidade (comeca 0.5 m/s ~ passo de gente)
#
# As pernas nao giram (cilindros simetricos): as teclas movem no frame do
# MUNDO. Sobe a bridge ROS->gz junto; Ctrl-C derruba tudo e para a pessoa.
set -e
source /opt/ros/jazzy/setup.bash
trap 'kill 0' EXIT
ros2 run ros_gz_bridge parameter_bridge \
  '/model/pessoa/cmd_vel@geometry_msgs/msg/Twist]gz.msgs.Twist' &
sleep 1
python3 - <<'EOF'
import select, sys, termios, tty

import rclpy
from geometry_msgs.msg import Twist

KEYS = {  # tecla -> (vx, vy) unitario no frame do mundo
    '8': (1, 0),  '2': (-1, 0), '4': (0, 1),  '6': (0, -1),
    '7': (1, 1),  '9': (1, -1), '1': (-1, 1), '3': (-1, -1),
    '5': (0, 0),  'k': (0, 0),
}

rclpy.init()
node = rclpy.create_node('teleop_pernas')
pub = node.create_publisher(Twist, '/model/pessoa/cmd_vel', 10)
speed, vx, vy = 0.5, 0.0, 0.0

old = termios.tcgetattr(sys.stdin)
tty.setcbreak(sys.stdin.fileno())
print('teleop-pernas: 8/2/4/6 dirige, diagonais 7/9/1/3, 5 PARA, +/- vel, '
      'Ctrl-C sai\r')
try:
    while True:
        if select.select([sys.stdin], [], [], 0.1)[0]:
            k = sys.stdin.read(1)
            if k == '\x03':
                break
            if k in KEYS:
                ux, uy = KEYS[k]
                n = (ux * ux + uy * uy) ** 0.5 or 1.0
                vx, vy = ux / n * speed, uy / n * speed
                print(f'v=({vx:+.2f},{vy:+.2f}) m/s\r')
            elif k in '+=':
                speed = min(1.5, speed + 0.1)
                print(f'vel {speed:.1f} m/s\r')
            elif k in '-_':
                speed = max(0.1, speed - 0.1)
                print(f'vel {speed:.1f} m/s\r')
        m = Twist()
        m.linear.x, m.linear.y = vx, vy
        pub.publish(m)
except KeyboardInterrupt:
    pass
finally:
    pub.publish(Twist())          # para a pessoa ao sair
    termios.tcsetattr(sys.stdin, termios.TCSADRAIN, old)
    rclpy.try_shutdown()
EOF

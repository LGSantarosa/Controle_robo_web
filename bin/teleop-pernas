#!/usr/bin/env bash
# teleop-pernas — dirige a "pessoa" (2 pernas do sala_grande.sdf) pelo TECLADO
# NUMERICO, estilo carrinho (igual o teleop_twist_keyboard sem shift: frente/
# re + giro/curva, SEM strafe), pra estressar o motion_guard no sim.
#
# Uso: com o sim de pe, rodar `bin/teleop-pernas` num terminal e dirigir com o
# foco NELE (a tecla fica valendo ate a proxima; 5 para):
#
#        7  8  9      8 = frente (pra onde ELA aponta)   2 = re
#        4  5  6      4 = gira esq   6 = gira dir   7/9 = curva em frente
#        1  2  3      1/3 = curva de re                  5 = PARA
#
#        + / -  = mais/menos velocidade (comeca 0.5 m/s ~ passo de gente)
#
# Sobe a bridge ROS->gz junto; Ctrl-C derruba tudo e para a pessoa.
set -e
source /opt/ros/jazzy/setup.bash
trap 'kill 0' EXIT
ros2 run ros_gz_bridge parameter_bridge \
  '/model/pessoa/cmd_vel@geometry_msgs/msg/Twist]gz.msgs.Twist' &
sleep 1
python3 - <<'EOF'
import select, termios, tty

import rclpy
from geometry_msgs.msg import Twist

KEYS = {  # tecla -> (frente, giro) unitarios — layout do teleop_twist_keyboard
    '8': (1, 0),  '2': (-1, 0), '4': (0, 1),  '6': (0, -1),
    '7': (1, 1),  '9': (1, -1), '1': (-1, -1), '3': (-1, 1),
    '5': (0, 0),  'k': (0, 0),
}
W_TURN = 1.2      # rad/s de giro no "unitario"

rclpy.init()
node = rclpy.create_node('teleop_pernas')
pub = node.create_publisher(Twist, '/model/pessoa/cmd_vel', 10)
speed, vx, wz = 0.5, 0.0, 0.0

kb = open('/dev/tty', 'rb', buffering=0)   # o heredoc rouba o stdin
old = termios.tcgetattr(kb)
tty.setcbreak(kb.fileno())
print('teleop-pernas: 8 frente / 2 re / 4-6 gira / 7-9-1-3 curva / 5 PARA / '
      '+/- vel / Ctrl-C sai\r')
try:
    while True:
        if select.select([kb], [], [], 0.1)[0]:
            k = kb.read(1).decode(errors='ignore')
            if k == '\x03':
                break
            if k in KEYS:
                ux, uw = KEYS[k]
                vx, wz = ux * speed, uw * W_TURN
                print(f'v={vx:+.2f} m/s  giro={wz:+.1f} rad/s\r')
            elif k in '+=':
                speed = min(1.5, speed + 0.1)
                vx = (vx > 0) * speed - (vx < 0) * speed
                print(f'vel {speed:.1f} m/s\r')
            elif k in '-_':
                speed = max(0.1, speed - 0.1)
                vx = (vx > 0) * speed - (vx < 0) * speed
                print(f'vel {speed:.1f} m/s\r')
        m = Twist()
        m.linear.x = float(vx)
        m.angular.z = float(wz)
        pub.publish(m)
except KeyboardInterrupt:
    pass
finally:
    pub.publish(Twist())          # para a pessoa ao sair
    termios.tcsetattr(kb, termios.TCSADRAIN, old)
    rclpy.try_shutdown()
EOF

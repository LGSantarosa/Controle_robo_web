#!/usr/bin/env bash
# teleop-pernas — dirige a "pessoa" (2 pernas do sala_grande.sdf) pelo TECLADO,
# pra estressar o motion_guard no sim sem depender de ninguem.
#
# Uso: com o sim de pe (./launch.sh --sim --nav2 --world=worlds/sala_grande.sdf ...),
#      rodar `bin/teleop-pernas` num terminal e dirigir com o foco NELE:
#        i = frente   , = re   j/l = gira   k = para
#        q/z = aumenta/diminui a velocidade (comeca em 0.5 m/s ~ passo de gente)
#
# Sobe a bridge ROS->gz do cmd_vel da pessoa e o teleop_twist_keyboard juntos;
# Ctrl-C derruba os dois. A pessoa nasce na sala decoy (6.5, 3.5) — leve ela
# ate a rota do robo e cruze na frente dele.
set -e
source /opt/ros/jazzy/setup.bash
trap 'kill 0' EXIT
ros2 run ros_gz_bridge parameter_bridge \
  '/model/pessoa/cmd_vel@geometry_msgs/msg/Twist]gz.msgs.Twist' &
sleep 1
ros2 run teleop_twist_keyboard teleop_twist_keyboard \
  --ros-args -r cmd_vel:=/model/pessoa/cmd_vel

#!/usr/bin/env bash
# Roda no OUTRO PC: pareia o controle PS4 no robô via SSH, num só comando.
# Pre-req:
#   1) Controle JÁ em modo pareamento (PS 10s pra apagar, SHARE+PS 5s pra
#      piscar RÁPIDO, solta — barra continua piscando rápido sozinha).
#   2) SSH passwordless configurado (ssh-copy-id) pro robô.
#   3) Sudo cacheado no robô — o script vai rodar `ssh ... sudo -v` pra você.
#
# Uso:
#   robot-pair-ps4
#
# Config (variáveis de ambiente, iguais às do robot-connect):
#   ROBOT_HOST   default: tenta robo-desktop.local; fallback pra IP fixo abaixo
#   ROBOT_USER   default: robo
#
# Por que existe: o pair via bluetoothctl no robô tem 6 pegadinhas (ver
# pair-ps4.sh §cabeçalho). Esse wrapper acha o repo no robô (via symlink em
# /usr/local/bin/robot-up) e roda ./pair-ps4.sh --no-prompt lá dentro.
set -euo pipefail

HOST_MDNS="robo-desktop.local"
REMOTE_USER="${ROBOT_USER:-robo}"

# Resolução de host: ROBOT_HOST override > mDNS. Sem fallback IP fixo: cada
# rede tem o seu, e um IP hardcoded "funciona em casa, falha em qualquer
# outro lugar". Mesma política do bin/robot-connect:14-16.
if [ -n "${ROBOT_HOST:-}" ]; then
    HOST="$ROBOT_HOST"
elif timeout 2 getent hosts "$HOST_MDNS" >/dev/null 2>&1; then
    HOST="$HOST_MDNS"
else
    cat >&2 <<EOF
ERRO: $HOST_MDNS não resolveu via mDNS.
  Passe o IP explicitamente:  ROBOT_HOST=<ip-do-robô> robot-pair-ps4
  (veja no painel do roteador, ou rode 'hostname -I' no robô).
EOF
    exit 1
fi

cat <<EOF

=== Pareamento do PS4 em ${REMOTE_USER}@${HOST} ===

Pre-checks:
  - Controle JÁ em modo pareamento? (barra piscando RÁPIDO, 2x/s)
  - Outros hosts que pareiam com esse controle (PC, outro robô): BT desligado?

EOF
read -r -p "Pronto? Enter pra começar (Ctrl+C cancela)... " _

# Resolve o checkout do repo no robô seguindo o symlink que o setup_headless.sh
# instalou em /usr/local/bin/robot-up. pair-ps4.sh sourceia scripts/_bluez_fixes.sh
# por path relativo — precisa rodar de dentro do repo, não copiado pra /tmp/.
echo "→ Localizando o repo no robô (via symlink em /usr/local/bin/robot-up)..."
REMOTE_REPO=$(ssh -o BatchMode=yes -o ConnectTimeout=5 "${REMOTE_USER}@${HOST}" \
    'dirname "$(dirname "$(readlink -f /usr/local/bin/robot-up 2>/dev/null)")"' 2>/dev/null || true)

if [ -z "$REMOTE_REPO" ] || ! ssh -o BatchMode=yes "${REMOTE_USER}@${HOST}" \
        "test -f '$REMOTE_REPO/pair-ps4.sh' && test -f '$REMOTE_REPO/scripts/_bluez_fixes.sh'" 2>/dev/null; then
    cat >&2 <<EOF
ERRO: não encontrei o repo no robô ou pair-ps4.sh/scripts/_bluez_fixes.sh ausentes.
  Rode no robô antes:
    cd ~/Workspace/Controle_robo_web && git pull && ./setup_pi.sh
EOF
    exit 1
fi
echo "  repo: ${REMOTE_USER}@${HOST}:${REMOTE_REPO}"

echo "→ Cacheando sudo + executando pair-ps4.sh no robô (mesmo PTY)..."
echo "  (vai pedir a senha de ${REMOTE_USER} 1x)"
echo
# sudo cache é por-PTY, então `sudo -v` e o `bash pair-ps4.sh` precisam estar
# no mesmo `ssh -t` (mesmo PTY).
ssh -t "${REMOTE_USER}@${HOST}" \
    "sudo -v && cd '$REMOTE_REPO' && bash pair-ps4.sh --no-prompt"

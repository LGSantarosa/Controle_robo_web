#!/usr/bin/env bash
# Teleop por teclado (WASD) publicando na entrada do twist_mux (key_vel, prio 90).
# PLANO_HEADLESS_2026-05-22 §4.4. Instalado em /usr/local/bin pelo setup_pi.sh.
#
# Rode num terminal SSH/tmux separado. O twist_mux arbitra: o PS4 (joy_vel,
# prio 100) vence o teclado; o teclado vence o Nav2/trekking (nav_vel, prio 10).
#
# Uso:  robot-key
set -euo pipefail

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_DIR="$(cd "$(dirname "$SELF")/.." && pwd)"
cd "$REPO_DIR"

# SSH não-interativo não lê o ~/.bashrc → ROS pode não estar sourceado.
# Tenta o workspace primeiro; senão cai pra distro base (/opt/ros/*/setup.bash).
if [ -f install/setup.bash ]; then
    # shellcheck disable=SC1091
    source install/setup.bash
else
    for d in /opt/ros/*/setup.bash; do
        # shellcheck disable=SC1090
        [ -f "$d" ] && source "$d" && break
    done
fi

if ! command -v ros2 >/dev/null 2>&1; then
    echo "ERRO: 'ros2' não encontrado. Source /opt/ros/<distro>/setup.bash ou rode ./start.sh pra compilar o workspace." >&2
    exit 1
fi

exec ros2 run teleop_twist_keyboard teleop_twist_keyboard \
    --ros-args -r cmd_vel:=key_vel
